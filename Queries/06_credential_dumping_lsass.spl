# Incident 6: Credential Dumping - LSASS
# Detection: Mimikatz execution or rundll32 invoking comsvcs.dll MiniDump
# Event: Sysmon Event ID 1 (Process Create)
# MITRE: TA0006 Credential Access - T1003.001 LSASS Memory

# Mimikatz binary
index=main EventCode=1 Image="*mimikatz*"
| table _time, User, Image, CommandLine
| sort _time

# comsvcs.dll MiniDump
index=main EventCode=1 Image="*rundll32*" CommandLine="*comsvcs*"
| table _time, User, Image, CommandLine
| sort _time
